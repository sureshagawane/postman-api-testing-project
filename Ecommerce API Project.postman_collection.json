    {
      "name": "Add Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "pm.test(\"Cart ID is not null\", function () {\r",
              "   pm.expect(jsonData.id).to.not.be.null;\r",
              "   });\r",
              "\r",
              "pm.environment.set(\"CartID\",jsonData.id)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"userId\": 1,\r\n    \"products\": [\r\n        {\r\n            \"id\": {{FirstProductId}},\r\n            \"quantity\": 4\r\n        }\r\n    ]\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/carts/add",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "carts",
            "add"
          ]
        }
